# ── Database credentials ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed to version control.
#
# Option A: Individual vars (recommended for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gradcafe
DB_USER=gradcafe_app
DB_PASSWORD=changeme

# Option B: Single URL (takes precedence over individual vars if set)
# DATABASE_URL=postgresql://gradcafe_app:changeme@localhost:5432/gradcafe

# ── Test database (used by pytest) ───────────────────────────────────────────
# DATABASE_URL=postgresql://localhost/gradcafe_test
