# Copy to .env for local (non-Docker) runs. .env is git-ignored — never commit it.
# Docker Compose sets these itself (see docker-compose.yml); you only need this
# file when running the services or tests directly on your host.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gradcafe:gradcafe@localhost:5432/gradcafe
# Or individual vars (used when DATABASE_URL is unset):
# DB_USER=gradcafe
# DB_PASSWORD=gradcafe
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=gradcafe

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Worker tuning ───────────────────────────────────────────────────────────
DATA_FILE=./src/data/applicant_data.json
INITIAL_LOAD_LIMIT=25000
SCRAPE_BATCH=500

# ── Tests ───────────────────────────────────────────────────────────────────
# The suite defaults to this DB when DATABASE_URL is unset:
# DATABASE_URL=postgresql://localhost/gradcafe_m6_test
