# Copy to .env ON THE EC2 HOST and fill in:  cp .env.example .env
# .env is git-ignored — NEVER commit the real file.
#
# Postgres and RabbitMQ are never exposed publicly (internal compose network
# only), but still pick a non-default POSTGRES_PASSWORD for a real deployment —
# and if you change it, update the password inside DATABASE_URL to match.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=gradcafe
POSTGRES_PASSWORD=gradcafe
POSTGRES_DB=gradcafe

# ── Connection URLs (web + worker reach db / rabbitmq by service name) ────────
DATABASE_URL=postgresql://gradcafe:gradcafe@db:5432/gradcafe
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Worker ETL tuning (mirrors the Module 6 defaults) ────────────────────────
INITIAL_LOAD_LIMIT=25000
SCRAPE_BATCH=500
