# Copy to .env for local runs:  cp .env.example .env
# .env is git-ignored — NEVER commit real values, and NEVER put AWS access keys
# here. On SageMaker, boto3 resolves credentials automatically from the notebook
# instance's IAM execution role (the default provider chain), so no keys are
# needed at all.

# AWS region of your S3 bucket (e.g. us-east-1). Leave blank to inherit the
# notebook/instance default region.
AWS_REGION=

# S3 source object and the local file the pipeline writes.
S3_BUCKET=grad-cafe
S3_KEY=applicant_data.json
OUTPUT_FILE=applicant_data_SM.json
